---
export const prerender = true;

import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Icon } from '@/assets/icons/icon';
import { postsFilter, workFilter } from '@/utils/collections/filters';
import { ArticleCard, FeaturedWorkCategory, HrIcon } from '@/components';
import type { PostMetadata, WorkMetadata } from '@/types/metadata';

const posts = (await getCollection('posts', postsFilter['filter-published-on-production']))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5)
  .map((p) => ({...p.data, slug: p.slug, id: p.id} satisfies PostMetadata));

const featuredWork = (await getCollection('work-category', workFilter['filter-featured']))
  .slice(0, 5)
  .map((p) => ({...p.data, id: p.id} satisfies WorkMetadata));

---

<Layout 
  title="Lazaro Osee | Designing Physical & Digital Spaces" 
  description='Portfolio and blog of Lazaro Osee, an architecture student and software developer. Discover projects bridging physical design and digital innovation.' 
  keywords="Lazaro Osee, Architecture Student, Software Developer, Digital Spaces, Web development Kenya" 
>
  <section slot="hero" class="hero">
    <div class="hero__div">
      <h1 class="title">
        Hi, I am <span>Lazaro</span>
      </h1>
      
      <p class="sub-title">
        Architecture student by day, software developer by night. 
        I design <span class="italic font-medium highlight">physical spaces</span> 
        and build <span class="italic font-medium highlight">digital ones</span>.
      </p>

      <div class="ctas__div">
        <a href="/posts" class="cta blog-cta">
          Read the Blog
        </a>
        <a href="/work" class="cta work-cta">
          View My Work
        </a>
      </div>
    </div>

    <div class="svg-wrapper" aria-hidden="true">
      <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <section id="work" class="work-preview">
    <h2 class="section-title">Featured Work</h2>
    <div class="work-grid">
      {featuredWork.map((w) => (
        <FeaturedWorkCategory {...w} />
      ))}
    </div>
  </section>
  
  <section class="notifications-section">
    <div class="notifications__card">
      <Icon name="bell" class="notifications__icon" />
      <h2 class="notifications__title">Stay in the loop</h2>
      <p class="notifications__description">
        Get notified directly in your browser whenever I publish new articles or launch new projects.
      </p>
      <button id="get-notified" class="notifications__button cta blog-cta">Get Notified</button>
    </div>
  </section>

  <section class="posts-section">
    <h2 class="posts__title">Recent Writing</h2>
    <HrIcon icon="book" /> 

    <ul class="posts__list">
      {posts.map((p, i) => (
        <li class="post-item">
          <ArticleCard {...p} />
          {(i + 1) < posts.length 
            ? <hr class="after-article" /> 
            : ""
          }
        </li>
      ))}
    </ul>
  </section>
</Layout>

<script>
import { subscribeUser } from "@/utils/frontend/push";


  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js')
      .then(reg => console.log('SW Registered!', reg))
      .catch(err => console.error('SW Registration failed!', err));
  }

  const notificationButton = document.getElementById('get-notified') as HTMLButtonElement;

  notificationButton.addEventListener('click', async (e) => {
      Notification.requestPermission().then(async permission => {
        if (permission === 'granted') {
          // Subscribe user
          const {message, success} = await subscribeUser();
          alert(message);
        }
      });
    // }
  });

  // Ensure service worker know the system theme for choosing notification icon
  const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

  const syncThemeWithSW = (isDark: boolean) => {
    if (navigator.serviceWorker.controller) {
      navigator.serviceWorker.controller.postMessage({
        type: 'THEME_CHANGE',
        isDark: isDark
      });
    }
  };

  // Send initial state
  syncThemeWithSW(mediaQuery.matches);

  // Listen for changes
  mediaQuery.addEventListener('change', (e) => syncThemeWithSW(e.matches));
</script>

<style>
  section {
    padding: 0;
    margin: 0;
  }
  .hero {
    & {
      display: block;
      width: stretch;
      position: relative;
      overflow: hidden;
      min-height: 70svh;
      padding: --space(1.5);
      padding-bottom: --space(5);
      font-family: "Grandstander", sans-serif;
      font-size: 1.25rem;
      line-height: 1.75;
      align-content: center safe;
      justify-items: center safe;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .hero__div {
      & {
        /* relative z-10 max-w-3xl */
        width: stretch;
        margin-inline: auto;
        position: relative;
        z-index: 10;
        max-width: 48rem;
        justify-items: center safe;
        align-content: center safe;
        align-items: center;
        justify-content: center;
      }
      .title {
        & {
          display: block;
          font-size: calc(2.6rem + 1vw);
          font-family: "Grandstander", sans-serif;
          font-weight: bold;
        }
        span {
          color: light-dark(rgb(121, 29, 29), rgb(166, 37, 37));
        }
      }
      p.sub-title {
        margin-bottom: --space(8);
      }
      .highlight {
        color: light-dark(var(--slate-800), var(--slate-200));
      }
      .ctas__div {
        &{
          display: flex;
          flex-wrap: wrap;
          justify-content: center;
          align-items: center;
          gap: max(--space(4), 1rem);
          margin-bottom: --space(2);
        }
        .cta {
          &{
            display: flex;
            align-items: center safe;
            justify-content: center safe;
            text-align: justify;
            text-box: trim-both ex alphabetic;
            padding: --space(2) --space(2);
            border-radius: 16rem;
            corner-shape: squircle;
            text-decoration: none;
            transition: transform 0.2s ease-in-out;
          }
          &:hover {
            transform: scale(1.15);
          }
        }
        .blog-cta {
          background-color: light-dark(rgb(121, 29, 29), white);
          border: light-dark(rgb(121, 29, 29), white)  0.15rem solid;
          color: light-dark(white, rgb(121, 29, 29));
        }
        .work-cta {
          border: light-dark(rgb(121, 29, 29), white) 0.15rem solid;
          color: light-dark(black, white);
          color: light-dark(rgb(121, 29, 29), white);
        }
      }
    }
    .svg-wrapper {
      & {
        /* absolute bottom-10 animate-bounce */
        position: absolute;
        bottom: --space(5);
        left: 50%;
        translate: -50% 0%;
        animation: bounceY 1s ease-in-out infinite;
      }
      svg {
        width: --space(12);
        height: --space(12);
      }
    }
  }
  .work-preview {
    padding: --space(12) --space(4);
    max-width: 80ch;
    margin-inline: auto;
    .section-title {
      font-family: "Grandstander", sans-serif;
      font-size: 2rem;
      text-align: center;
      margin-bottom: --space(8);
    }
    .work-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: --space(6);
    }
  }
  .posts-section {
    &{
      display: block;
      width: stretch;
      max-width: 80ch;
      margin-inline: auto;
      align-content: center safe;
      justify-items: center safe;
      padding: 0 --space(4);
    }
    .posts__title {
      text-align: center;
      width: 100%;
      display: block;
    }
    ul.posts__list {
      &{
        display: block;
        list-style: none;
        width: stretch;
        max-width: 60ch;
        padding: 0;
        margin-inline: auto;
        justify-items: center safe;
        align-content: center safe;
      }
      .posts__title {
        font-size: xx-large;
        font-family: "Grandstander", sans-serif;
        font-weight: normal;
        color: light-dark(rgb(121, 29, 29), white);
        line-height: 1.5;
      }
      li {
        & {
          display: block;
          padding: --space(0.5) --space(0.25);
          justify-items: center safe;
          align-content: center safe;
        }
      }
      hr.after-article { margin: --space(9) auto --space(3); border: none; border-top: 0.1rem solid; }
    }
  }
  .notifications-section {
    display: flex;
    justify-content: center;
    padding: --space(12) --space(4);
  }
  .notifications__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 40rem;
    padding: --space(8);
    border: 2px dashed light-dark(rgba(121, 29, 29, 0.3), rgba(255, 255, 255, 0.3));
    border-radius: 4rem;
    background-color: light-dark(rgba(121, 29, 29, 0.03), rgba(255, 255, 255, 0.03));
    corner-shape: squircle;
  }
  .notifications__icon {
    width: --space(10);
    height: --space(10);
    margin-bottom: --space(4);
    color: light-dark(rgb(121, 29, 29), white);
    fill: light-dark(rgb(121, 29, 29), white);
  }
  .notifications__title {
    font-family: "Grandstander", sans-serif;
    font-size: 1.75rem;
    margin-bottom: --space(2);
  }
  .notifications__description {
    font-size: 1.1rem;
    margin-bottom: --space(6);
    opacity: 0.9;
  }
  .notifications__button {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: light-dark(rgb(121, 29, 29), white);
    color: light-dark(white, rgb(121, 29, 29));
  }
</style>
