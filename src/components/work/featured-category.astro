---
import { Icon } from "@/assets/icons/icon";
import type { WorkMetadata } from "@/types/metadata";
interface Props extends WorkMetadata {}

const { icon,subtitle,title , id } = Astro.props;
---


<a href={`/work/${id}`} class="work-item">
    <Icon name={icon} class="icon-primary" />
    <h3>{title}</h3>
    <p>{subtitle}</p>
</a>

<style>
    a {
        text-decoration: none;
        color: inherit;
    }
    .work-item {
        &{
            padding: --space(6);
            border: 1px solid light-dark(rgba(0,0,0,0.1), rgba(255,255,255,0.1));
            border-radius: 1rem;
        }
      h3 {
        font-family: "Grandstander", sans-serif;
        margin: --space(2) 0;
      }
      svg {
        width: 2rem;
        height: 2rem;
      }
    }
</style>
